# Google Sign-In (Google Identity Services)
#
# Create an OAuth client ID at:
#   https://console.cloud.google.com/apis/credentials
#   -> Create credentials -> OAuth client ID -> Application type: Web application
#
# Under "Authorized JavaScript origins" add every origin the app runs on, e.g.:
#   http://localhost:5173
#   https://swapmyshow.pages.dev
#
# Then copy this file to .env.local and paste your client id below.
# (The OAuth client id is public — it ships in the browser bundle — but keep
#  it in an env file rather than hard-coding it.)
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Base URL of the SwapMyShow backend (Cloudflare Worker) that verifies the
# Google token and issues session tokens. No trailing slash.
#   local:      http://127.0.0.1:8787
#   production: https://swapmyshow-backend.<your-subdomain>.workers.dev
VITE_API_URL=http://127.0.0.1:8787
